{
  "name": "sanity-plugin-soundcloud-input",
  "version": "1.0.0",
  "description": "A plugin for using SoundCloud data in Sanity.",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "soundcloud",
    "soundcloud-plugin"
  ],
  "homepage": "https://github.com/damianrosellen1/sanity-plugin-soundcloud-input#readme",
  "bugs": {
    "url": "https://github.com/damianrosellen1/sanity-plugin-soundcloud-input/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/damianrosellen1/sanity-plugin-soundcloud-input.git"
  },
  "license": "MIT",
  "author": "Damian Rosellen <hi@damianrosellen.de>",
  "sideEffects": false,
  "type": "commonjs",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "clean": "rimraf dist",
    "format": "prettier --write --cache --ignore-unknown .",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "watch": "pkg-utils watch --strict"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "sanity.json",
    "src",
    "v2-incompatible.js"
  ],
  "dependencies": {
    "@sanity/browserslist-config": "^1.0.3",
    "@sanity/icons": "^3.4.0",
    "@sanity/incompatible-plugin": "^1.0.4",
    "@sanity/ui": "^2.8.23",
    "browserslist": "extends @sanity/browserslist-config",
    "yalc": "1.0.0-pre.53"
  },
  "peerDependencies": {
    "react": "^18",
    "sanity": "^3"
  },
  "engines": {
    "node": ">=18"
  },
  "yalcSig": "f624edddbbf41b97746e65d577210c79"
}
