{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/README.md",
			"!**/*.gen.ts",
			"!studio/schema.json",
			"!**/*.svg",
			"!**/.nuxt",
			"!**/.output",
			"!**/dist"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"a11y": {
				"noSvgWithoutTitle": "warn",
				"useAltText": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"useIterableCallbackReturn": "warn"
			},
			"correctness": {
				"noUnusedVariables": "warn",
				"noUnusedImports": "warn",
				"noUnsafeOptionalChaining": "warn",
				"noUnreachable": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["studio/**"],
			"formatter": {
				"indentStyle": "space",
				"indentWidth": 2
			}
		},
		{
			"includes": ["**/*.vue"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			"includes": [
				"web/app/pages/**",
				"web/app/error.vue",
				"web/layers/base/components/libretime/**"
			],
			"linter": {
				"rules": {
					"style": {
						"useVueMultiWordComponentNames": "off"
					}
				}
			}
		}
	]
}
