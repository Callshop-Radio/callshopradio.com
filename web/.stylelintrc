{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-recommended-vue"
  ],
  "plugins": [
    "stylelint-order"
  ],
  "rules": {
    "order/order": [
      "custom-properties",
      "declarations"
    ],
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "apply"
        ]
      }
    ]
  }
}