.page-leave-active,
.page-enter-active {
  /* out-in mode runs leave then enter sequentially, so keep each phase short. */
  @apply transition-opacity duration-200;
}

.page-enter-from,
.page-leave-to {
  @apply opacity-0;
}

.fade-enter-active,
.fade-leave-active {
  @apply transition-opacity duration-400;
}

.fade-enter-from,
.fade-leave-to {
  @apply opacity-0;
}
