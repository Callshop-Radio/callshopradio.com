.page-leave-active,
.page-enter-active {
  /* out-in runs leave then enter sequentially — keep each phase short so the
     total stays snappy (~300ms). */
  @apply transition-opacity duration-150;
}

.page-enter-from,
.page-leave-to {
  @apply opacity-0;
}

.fade-enter-active,
.fade-leave-active {
  @apply transition-opacity duration-400;
}

.fade-enter-from,
.fade-leave-to {
  @apply opacity-0;
}
